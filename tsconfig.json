{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strictNullChecks": true,
    "noImplicitAny": false
  },
  "include": [
    "algorithms/**/*.js",
    "visualizer/**/*.js",
    "manifest.js",
    "types/**/*.d.ts"
  ]
}
